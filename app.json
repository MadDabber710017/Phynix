{
  "expo": {
    "name": "CannaGrow",
    "slug": "cannagrow",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "cannagrow",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0d1a0f"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.cannagrow"
    },
    "android": {
      "package": "com.cannagrow",
      "adaptiveIcon": {
        "backgroundColor": "#0d1a0f",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      }
    },
    "web": {
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      [
        "expo-router",
        {
          "origin": "https://replit.com/"
        }
      ],
      "expo-font",
      "expo-web-browser",
      [
        "expo-image-picker",
        {
          "photosPermission": "CannaGrow needs access to your photos to analyze your plants.",
          "cameraPermission": "CannaGrow needs camera access to analyze your plants."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
